# Narrative Nexus Configuration
APP_NAME=Narrative Nexus
APP_VERSION=4.0.0
DEBUG=True

# Server
HOST=0.0.0.0
PORT=8000

# LLM Configuration
LLM_PROVIDER=ollama
LLM_MODEL=llama2
LLM_BASE_URL=http://localhost:11434

# Vector Database
CHROMA_PERSIST_DIR=./chroma_db
CHROMA_COLLECTION_NAME=narrative_nexus

# Memory System
MEMORY_TOP_K=5
MEMORY_SIMILARITY_THRESHOLD=0.7

# CORS
CORS_ORIGINS=["http://localhost:3000", "http://localhost:5173"]
